#!/usr/bin/env bash
# dstack context-monitor hook (async)
# Tracks tool call count as proxy for context usage
# Warns when context is getting heavy

set -euo pipefail

COUNTER_FILE="${TMPDIR:-/tmp}/dstack-context-count"

# Increment counter
COUNT=0
if [ -f "$COUNTER_FILE" ]; then
  COUNT=$(cat "$COUNTER_FILE")
fi
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# Warn at thresholds
if [ "$COUNT" -eq 50 ]; then
  echo "dstack: 50 tool calls in this session. Consider saving important findings with 'dstack memory save'."
elif [ "$COUNT" -eq 100 ]; then
  echo "dstack: 100 tool calls. Context is getting heavy. Save key learnings before they're lost to compaction."
fi
