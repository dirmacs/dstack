#!/usr/bin/env bash
# dstack context-monitor hook (PostToolUse, async)
# Tracks tool call count, warns at thresholds

set -euo pipefail

COUNTER_FILE="${TMPDIR:-/tmp}/dstack-context-count-$$"

COUNT=0
if [ -f "$COUNTER_FILE" ]; then
  COUNT=$(cat "$COUNTER_FILE")
fi
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# Only emit context at warning thresholds
MSG=""
if [ "$COUNT" -eq 50 ]; then
  MSG="dstack: 50 tool calls this session. Consider saving important findings with 'dstack memory save'."
elif [ "$COUNT" -eq 100 ]; then
  MSG="dstack: 100 tool calls. Context is heavy. Save key learnings before compaction."
fi

if [ -n "$MSG" ]; then
  escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
  }
  escaped=$(escape_for_json "$MSG")
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PostToolUse",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
fi

exit 0
